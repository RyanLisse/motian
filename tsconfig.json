{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "trigger.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "drizzle",
    "tests",
    "extension",
    "fumadocs",
    "scripts",
    "opentui-demo",
    "tui",
    "agent"
  ]
}
