# Database primary (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Database fallback (Turso / libSQL) - optional backup path
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Scraping - Browserbase (voor Striive + andere authenticated platforms)
BROWSERBASE_API_KEY=bb-XXXXXXXXXXXXXXXXXXXXXXXX
BROWSERBASE_PROJECT_ID=proj-XXXXXXXXXXXXXXXX

# Scraping - Firecrawl (voor public platforms later)
FIRECRAWL_API_KEY=fc-XXXXXXXXXXXXXXXXXXXXXXXX

# Motia API (voor Next.js Server Components)
MOTIA_API_URL=http://localhost:3000

# Next.js URL (voor cache revalidatie vanuit Motia steps)
NEXT_URL=http://localhost:3001
PUBLIC_API_BASE_URL=http://localhost:3001
HOSTNAME=0.0.0.0
PORT=3001

# Externe API toegang
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
API_SECRET=vervang_dit_met_een_lang_geheim_token

# Encryptie (genereer met: openssl rand -base64 32)
ENCRYPTION_KEY=jouw_encryptie_sleutel_hier

# Platform credentials (NOOIT in code)
STRIIVE_USERNAME=jouw_email@voorbeeld.nl
STRIIVE_PASSWORD=jouw_wachtwoord_hier
STRIIVE_SESSION_COOKIE=optioneel_cookie_override
STRIIVE_USE_MODAL=true

# Modal (sandbox voor Playwright op Vercel)
MODAL_TOKEN_ID=ak-XXXXXXXXXXXXXXXXXXXXXXXX
MODAL_TOKEN_SECRET=as-XXXXXXXXXXXXXXXXXXXXXXXX

LINKEDIN_USERNAME=jouw_linkedin_email@voorbeeld.nl
LINKEDIN_PASSWORD=jouw_linkedin_wachtwoord_hier

# AI Chat (Anthropic Claude via AI SDK)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Google AI (Gemini via AI SDK + voice agent)
GOOGLE_GENERATIVE_AI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXX

# AI Enrichment + Embeddings (OpenAI)
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX

# xAI Grok (Judge — second-opinion on match evaluations)
X_AI_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXX

# Sentry (error tracking + performance)
SENTRY_DSN=https://your_token_here@your_token_here.ingest.sentry.io/your_project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_token_here@your_token_here.ingest.sentry.io/your_project_id
SENTRY_ORG=motian
SENTRY_PROJECT=motian-recruitment

# ⚠️  SECURITY WARNING: SENTRY_AUTH_TOKEN grants write access to releases and source maps
# Do NOT commit this token to git. Use Vercel environment variables for deployment.
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, org:read
# SENTRY_AUTH_TOKEN=your_token_here

# LangSmith (AI pipeline tracing — optioneel)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls_xxx
LANGSMITH_PROJECT=motian-production
# Aanbevolen voor Vercel AI SDK tracing op Vercel / server runtimes
OTEL_ENABLED=true
# Legacy compatibiliteit: LANGCHAIN_* blijft ondersteund als LANGSMITH_* niet gezet is
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_xxx
# LANGCHAIN_PROJECT=motian-production

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Slack (recruiter notificaties — optioneel)
SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXXXXXXXXXXXXXX
SLACK_CHANNEL_ID=C0XXXXXXXX

# Scoring configuratie (standaard: skills=40, location=20, rate=20, role=20)
SCORING_WEIGHT_SKILLS=40
SCORING_WEIGHT_LOCATION=20
SCORING_WEIGHT_RATE=20
SCORING_WEIGHT_ROLE=20

# Hybride scoring blend (standaard: 60% regelgebaseerd, 40% semantisch)
HYBRID_BLEND_RULE=0.6
HYBRID_BLEND_VECTOR=0.4

# Recency scoring configuratie (tijd-afhankelijke score aanpassingen)
# RECENCY_BOOST_DAYS: aantal dagen waarbinnen recente matches een boost krijgen (default: 30)
# RECENCY_PENALTY_DAYS: aantal dagen waarna verouderde matches een penalty krijgen (default: 60)
# RECENCY_BOOST_AMOUNT: punten boost voor recente matches (default: 5)
# RECENCY_PENALTY_AMOUNT: punten penalty voor verouderde matches (default: 5)
RECENCY_BOOST_DAYS=30
RECENCY_PENALTY_DAYS=60
RECENCY_BOOST_AMOUNT=5
RECENCY_PENALTY_AMOUNT=5

# Quality signals scoring configuratie (goedkeuringsrate gebaseerde score aanpassingen)
# QUALITY_SIGNAL_DECAY_DAYS: aantal dagen match geschiedenis om te beschouwen voor goedkeuringssnelheid (default: 90)
# QUALITY_HIGH_APPROVAL_THRESHOLD: drempel voor hoge goedkeuringsrate in percent (default: 70)
# QUALITY_LOW_APPROVAL_THRESHOLD: drempel voor lage goedkeuringsrate in percent (default: 30)
# QUALITY_HIGH_APPROVAL_BOOST: punten boost voor kandidaten met ≥70% goedkeuring (default: 5)
# QUALITY_LOW_APPROVAL_PENALTY: punten penalty voor kandidaten met <30% goedkeuring (default: 5)
# QUALITY_MIN_DECISIONS: minimum aantal beslissingen vereist voordat signaal van toepassing is (default: 3)
QUALITY_SIGNAL_DECAY_DAYS=90
QUALITY_HIGH_APPROVAL_THRESHOLD=70
QUALITY_LOW_APPROVAL_THRESHOLD=30
QUALITY_HIGH_APPROVAL_BOOST=5
QUALITY_LOW_APPROVAL_PENALTY=5
QUALITY_MIN_DECISIONS=3

# LiveKit (voice agent — optioneel)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIXXXXXXXXXXXXXXXX
LIVEKIT_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
