{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@motian/db": ["./packages/db/src/index.ts"],
      "@motian/db/*": ["./packages/db/src/*"],
      "@motian/esco": ["./packages/esco/src/index.ts"],
      "@motian/esco/*": ["./packages/esco/src/*"],
      "@motian/scrapers": ["./packages/scrapers/src/index.ts"],
      "@motian/scrapers/*": ["./packages/scrapers/src/*"]
    }
  }
}
