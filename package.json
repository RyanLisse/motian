{
  "name": "recruitment-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-Assisted Recruitment Operations Platform — Motia.dev + Drizzle + Neon",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:coverage": "vitest run --coverage",
    "track:ai-costs": "npx ccusage",
    "harness:risk-tier": "tsx scripts/harness/risk-policy-gate.ts",
    "harness:pre-pr": "pnpm lint && pnpm exec tsc --noEmit && pnpm test && tsx scripts/harness/risk-policy-gate.ts",
    "harness:smoke": "vitest run tests/harness/",
    "harness:browser-evidence": "tsx scripts/harness/capture-browser-evidence.ts",
    "harness:verify-evidence": "tsx scripts/harness/verify-browser-evidence.ts",
    "harness:entropy": "tsx scripts/harness/entropy-check.ts",
    "harness:gap": "tsx scripts/harness/create-gap-issue.ts",
    "harness:weekly-metrics": "tsx scripts/harness/entropy-check.ts --verbose"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/react": "^3.0.99",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.97",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.38.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.575.0",
    "modal": "^0.6.3",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.13.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@storybook/nextjs-vite": "^10.2.10",
    "@storybook/react": "^10.2.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.30.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "storybook": "^10.2.10",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
